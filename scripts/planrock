#!/usr/bin/env node

const fs = require("fs");
const path = require("path");

const STATUS_LIMIT = 10;
const PRIORITIES = ["P0", "P1", "P2", "P3", "P4"];
const DEFAULT_PRIORITY = "P2";

function parseArgs(argv) {
  const args = [...argv];
  const options = {
    command: "status",
    json: false,
    workingDir: null,
    sort: "priority",
  };

  for (let index = 0; index < args.length; index += 1) {
    const arg = args[index];

    if (arg === "--json") {
      options.json = true;
    } else if (arg === "--working-dir" || arg === "--workspace") {
      const value = args[index + 1];
      if (!value) {
        throw new Error(`${arg} requires a path`);
      }
      options.workingDir = value;
      index += 1;
    } else if (arg.startsWith("--working-dir=")) {
      options.workingDir = arg.slice("--working-dir=".length);
    } else if (arg.startsWith("--workspace=")) {
      options.workingDir = arg.slice("--workspace=".length);
    } else if (arg === "--sort") {
      const value = args[index + 1];
      if (!value) {
        throw new Error("--sort requires priority or time");
      }
      options.sort = parseSort(value);
      index += 1;
    } else if (arg.startsWith("--sort=")) {
      options.sort = parseSort(arg.slice("--sort=".length));
    } else if (["status", "open", "closed"].includes(arg)) {
      options.command = arg;
    } else if (arg === "--help" || arg === "-h") {
      options.command = "help";
    } else {
      throw new Error(`Unknown argument: ${arg}`);
    }
  }

  return options;
}

function parseSort(value) {
  if (value === "priority" || value === "time") {
    return value;
  }

  throw new Error(`Unknown sort: ${value}`);
}

function resolveWorkingDir(workingDirOption) {
  if (workingDirOption) {
    return path.resolve(workingDirOption);
  }

  if (process.env.PLANROCK_WORKING_DIR) {
    return path.resolve(process.env.PLANROCK_WORKING_DIR);
  }

  if (process.env.PLANROCK_WORKSPACE) {
    return path.resolve(process.env.PLANROCK_WORKSPACE);
  }

  return process.cwd();
}

function parseFrontmatter(content) {
  if (!content.startsWith("---\n")) {
    return {};
  }

  const end = content.indexOf("\n---", 4);
  if (end === -1) {
    return {};
  }

  const frontmatter = content.slice(4, end).split(/\r?\n/);
  const values = {};

  for (const line of frontmatter) {
    const match = line.match(/^([A-Za-z0-9_-]+):\s*(.*)$/);
    if (!match) {
      continue;
    }

    const key = match[1];
    let value = match[2].trim();

    if (
      (value.startsWith('"') && value.endsWith('"')) ||
      (value.startsWith("'") && value.endsWith("'"))
    ) {
      value = value.slice(1, -1);
    }

    values[key] = value;
  }

  return values;
}

function countChecklistItems(content) {
  const totalMatches = content.match(/^\s*-\s+\[[ xX]\]/gm) || [];
  const doneMatches = content.match(/^\s*-\s+\[[xX]\]/gm) || [];

  return {
    done: doneMatches.length,
    total: totalMatches.length,
  };
}

function completionPercent(done, total) {
  if (total === 0) {
    return 0;
  }

  return Math.round((done / total) * 100);
}

function normalizePriority(priority) {
  return PRIORITIES.includes(priority) ? priority : DEFAULT_PRIORITY;
}

function readPlans(plansDir, sort = "priority") {
  if (!fs.existsSync(plansDir)) {
    throw new Error(
      `Warning: no plans/ directory found in the current working directory. Expected saved plans under: ${plansDir}`,
    );
  }

  const filenames = fs
    .readdirSync(plansDir, { withFileTypes: true })
    .filter((entry) => entry.isFile() && entry.name.endsWith(".md"))
    .map((entry) => entry.name)
    .sort();

  const openPlans = [];
  const closedPlans = [];

  for (const filename of filenames) {
    const fullPath = path.join(plansDir, filename);
    const content = fs.readFileSync(fullPath, "utf8");
    const frontmatter = parseFrontmatter(content);
    const checklist = countChecklistItems(content);

    const plan = {
      file: path.join("plans", filename),
      title: frontmatter.title || filename,
      state: frontmatter.state || "",
      priority: normalizePriority(frontmatter.priority),
      createdAt: frontmatter.created_at || "",
      closedAt: frontmatter.closed_at || "",
      agentSession: frontmatter.agent_session || "",
      checklistDone: checklist.done,
      checklistTotal: checklist.total,
      completionPercent: completionPercent(checklist.done, checklist.total),
    };

    if (plan.state === "open") {
      openPlans.push(plan);
    } else if (plan.state === "closed") {
      closedPlans.push(plan);
    }
  }

  openPlans.sort((a, b) => compareOpenPlans(a, b, sort));
  closedPlans.sort((a, b) => compareDatesDescending(a.closedAt, b.closedAt));

  return { openPlans, closedPlans };
}

function compareDatesDescending(a, b) {
  return b.localeCompare(a);
}

function compareOpenPlans(a, b, sort) {
  if (sort === "time") {
    return compareDatesDescending(a.createdAt, b.createdAt);
  }

  const priorityDifference =
    PRIORITIES.indexOf(a.priority) - PRIORITIES.indexOf(b.priority);
  if (priorityDifference !== 0) {
    return priorityDifference;
  }

  return compareDatesDescending(a.createdAt, b.createdAt);
}

function createReport(workingDir, openPlans, closedPlans) {
  return {
    workingDir,
    summary: {
      open: openPlans.length,
      closed: closedPlans.length,
    },
    openPlans,
    closedPlans,
  };
}

function padRight(value, width) {
  return String(value).padEnd(width, " ");
}

function printTable(rows, columns) {
  if (rows.length === 0) {
    console.log("  (none)");
    return;
  }

  const widths = columns.map((column) =>
    Math.max(
      column.label.length,
      ...rows.map((row) => String(column.value(row)).length),
    ),
  );

  console.log(
    columns
      .map((column, index) => padRight(column.label, widths[index]))
      .join("  "),
  );
  console.log(widths.map((width) => "-".repeat(width)).join("  "));

  for (const row of rows) {
    console.log(
      columns
        .map((column, index) => padRight(column.value(row), widths[index]))
        .join("  "),
    );
  }
}

function printSummary(summary) {
  console.log("Planrock Status");
  console.log(`Open:   ${summary.open}`);
  console.log(`Closed: ${summary.closed}`);
}

function printOpenPlans(plans) {
  console.log("Open Plans");
  printTable(plans, [
    { label: "Priority", value: (plan) => plan.priority },
    { label: "Agent Session", value: (plan) => plan.agentSession || "-" },
    { label: "Created", value: (plan) => plan.createdAt },
    { label: "Done", value: (plan) => plan.checklistDone },
    { label: "Total", value: (plan) => plan.checklistTotal },
    { label: "Percent", value: (plan) => `${plan.completionPercent}%` },
    { label: "Title", value: (plan) => plan.title },
  ]);
}

function printClosedPlans(plans) {
  console.log("Closed Plans");
  printTable(plans, [
    { label: "Closed", value: (plan) => plan.closedAt },
    { label: "Created", value: (plan) => plan.createdAt },
    { label: "Title", value: (plan) => plan.title },
  ]);
}

function printHumanReport(command, report) {
  console.log(`Working dir: ${report.workingDir}`);

  if (command === "open") {
    printOpenPlans(report.openPlans);
    return;
  }

  if (command === "closed") {
    printClosedPlans(report.closedPlans);
    return;
  }

  printSummary(report.summary);
  console.log("");
  console.log(`Top Open Plans (top ${STATUS_LIMIT})`);
  printTable(report.openPlans.slice(0, STATUS_LIMIT), [
    { label: "Priority", value: (plan) => plan.priority },
    { label: "Agent Session", value: (plan) => plan.agentSession || "-" },
    { label: "Created", value: (plan) => plan.createdAt },
    { label: "Done", value: (plan) => plan.checklistDone },
    { label: "Total", value: (plan) => plan.checklistTotal },
    { label: "Percent", value: (plan) => `${plan.completionPercent}%` },
    { label: "Title", value: (plan) => plan.title },
  ]);
  console.log("");
  console.log(`Most Recent Closed Plans (top ${STATUS_LIMIT})`);
  printTable(report.closedPlans.slice(0, STATUS_LIMIT), [
    { label: "Closed", value: (plan) => plan.closedAt },
    { label: "Created", value: (plan) => plan.createdAt },
    { label: "Title", value: (plan) => plan.title },
  ]);
}

function printJsonReport(command, report) {
  if (command === "open") {
    console.log(
      JSON.stringify(
        { workingDir: report.workingDir, openPlans: report.openPlans },
        null,
        2,
      ),
    );
    return;
  }

  if (command === "closed") {
    console.log(
      JSON.stringify(
        { workingDir: report.workingDir, closedPlans: report.closedPlans },
        null,
        2,
      ),
    );
    return;
  }

  console.log(
    JSON.stringify(
      {
        workingDir: report.workingDir,
        summary: report.summary,
        recentOpenPlans: report.openPlans.slice(0, STATUS_LIMIT),
        recentClosedPlans: report.closedPlans.slice(0, STATUS_LIMIT),
      },
      null,
      2,
    ),
  );
}

function printHelp() {
  console.log(`Usage: planrock [status|open|closed] [--working-dir <path>] [--sort priority|time] [--json]

Commands:
  status   Show summary plus the 10 highest-priority open plans and 10 most recent closed plans.
  open     Show all open plans, priority first by default.
  closed   Show all closed plans, newest closed first.

Options:
  --working-dir <path>  Working directory containing plans/.
  --sort priority|time  Sort open plans by priority then created time, or by created time only.
  --json                Emit machine-readable JSON.
`);
}

function main() {
  let options;

  try {
    options = parseArgs(process.argv.slice(2));
  } catch (error) {
    console.error(error.message);
    console.error("Usage: planrock [status|open|closed] [--working-dir <path>] [--sort priority|time] [--json]");
    process.exit(1);
  }

  if (options.command === "help") {
    printHelp();
    return;
  }

  const workingDir = resolveWorkingDir(options.workingDir);
  const plansDir = path.join(workingDir, "plans");
  let openPlans;
  let closedPlans;

  try {
    ({ openPlans, closedPlans } = readPlans(plansDir, options.sort));
  } catch (error) {
    console.error(error.message);
    process.exit(1);
  }

  const report = createReport(workingDir, openPlans, closedPlans);

  if (options.json) {
    printJsonReport(options.command, report);
    return;
  }

  printHumanReport(options.command, report);
}

main();
