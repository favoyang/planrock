#!/usr/bin/env node

const fs = require("fs");
const path = require("path");
const packageJson = require("../package.json");

const STATUS_LIMIT = 10;
const PRIORITIES = ["P0", "P1", "P2", "P3", "P4"];
const DEFAULT_PRIORITY = "P2";

function parseArgs(argv) {
  const args = [...argv];
  const options = {
    command: "status",
    json: false,
    fullAgentSession: false,
    workingDir: null,
    sort: "priority",
    planPath: null,
  };

  for (let index = 0; index < args.length; index += 1) {
    const arg = args[index];

    if (arg === "--json") {
      options.json = true;
    } else if (arg === "--full-agent-session") {
      options.fullAgentSession = true;
    } else if (arg === "--working-dir" || arg === "--workspace") {
      const value = args[index + 1];
      if (!value) {
        throw new Error(`${arg} requires a path`);
      }
      options.workingDir = value;
      index += 1;
    } else if (arg.startsWith("--working-dir=")) {
      options.workingDir = arg.slice("--working-dir=".length);
    } else if (arg.startsWith("--workspace=")) {
      options.workingDir = arg.slice("--workspace=".length);
    } else if (arg === "--sort") {
      const value = args[index + 1];
      if (!value) {
        throw new Error("--sort requires priority or time");
      }
      options.sort = parseSort(value);
      index += 1;
    } else if (arg.startsWith("--sort=")) {
      options.sort = parseSort(arg.slice("--sort=".length));
    } else if (options.command === "goal" && !options.planPath) {
      options.planPath = arg;
    } else if (["status", "open", "closed", "goal"].includes(arg)) {
      options.command = arg;
    } else if (arg === "--help" || arg === "-h") {
      options.command = "help";
    } else if (arg === "--version") {
      options.command = "version";
    } else {
      throw new Error(`Unknown argument: ${arg}`);
    }
  }

  return options;
}

function parseSort(value) {
  if (value === "priority" || value === "time") {
    return value;
  }

  throw new Error(`Unknown sort: ${value}`);
}

function resolveWorkingDir(workingDirOption) {
  if (workingDirOption) {
    return path.resolve(workingDirOption);
  }

  if (process.env.PLANROCK_WORKING_DIR) {
    return path.resolve(process.env.PLANROCK_WORKING_DIR);
  }

  if (process.env.PLANROCK_WORKSPACE) {
    return path.resolve(process.env.PLANROCK_WORKSPACE);
  }

  return process.cwd();
}

function parseFrontmatter(content) {
  if (!content.startsWith("---\n")) {
    return {};
  }

  const end = content.indexOf("\n---", 4);
  if (end === -1) {
    return {};
  }

  const frontmatter = content.slice(4, end).split(/\r?\n/);
  const values = {};

  for (let index = 0; index < frontmatter.length; index += 1) {
    const line = frontmatter[index];
    const match = line.match(/^([A-Za-z0-9_-]+):\s*(.*)$/);
    if (!match) {
      continue;
    }

    const key = match[1];
    const value = match[2].trim();

    if (value === "") {
      const items = [];
      let nextIndex = index + 1;

      while (nextIndex < frontmatter.length) {
        const itemMatch = frontmatter[nextIndex].match(/^\s*-\s*(.*)$/);
        if (!itemMatch) {
          break;
        }

        items.push(unquoteValue(itemMatch[1].trim()));
        nextIndex += 1;
      }

      values[key] = items.length > 0 ? items : value;
      index = nextIndex - 1;
      continue;
    }

    values[key] = unquoteValue(value);
  }

  return values;
}

function unquoteValue(value) {
  if (
    (value.startsWith('"') && value.endsWith('"')) ||
    (value.startsWith("'") && value.endsWith("'"))
  ) {
    return value.slice(1, -1);
  }

  return value;
}

function normalizeAgentSessions(frontmatter) {
  if (Array.isArray(frontmatter.agent_sessions)) {
    return frontmatter.agent_sessions.filter((session) => session !== "");
  }

  if (frontmatter.agent_sessions) {
    if (frontmatter.agent_sessions === "[]") {
      return [];
    }

    return [frontmatter.agent_sessions];
  }

  if (frontmatter.agent_session) {
    return [frontmatter.agent_session];
  }

  return [];
}

function formatAgentSessionId(session, fullAgentSession) {
  if (fullAgentSession) {
    return session;
  }

  const separatorIndex = session.indexOf(":");
  if (separatorIndex === -1) {
    return session.slice(0, 8);
  }

  const agentName = session.slice(0, separatorIndex);
  const sessionId = session.slice(separatorIndex + 1);
  return `${agentName}:${sessionId.slice(0, 8)}`;
}

function countChecklistItems(content) {
  const totalMatches = content.match(/^\s*-\s+\[[ xX]\]/gm) || [];
  const doneMatches = content.match(/^\s*-\s+\[[xX]\]/gm) || [];

  return {
    done: doneMatches.length,
    total: totalMatches.length,
  };
}

function completionPercent(done, total) {
  if (total === 0) {
    return 0;
  }

  return Math.round((done / total) * 100);
}

function normalizePriority(priority) {
  return PRIORITIES.includes(priority) ? priority : DEFAULT_PRIORITY;
}

function readPlans(plansDir, sort = "priority") {
  if (!fs.existsSync(plansDir)) {
    throw new Error(
      `Warning: no plans/ directory found in the current working directory. Expected saved plans under: ${plansDir}`,
    );
  }

  const filenames = fs
    .readdirSync(plansDir, { withFileTypes: true })
    .filter((entry) => entry.isFile() && entry.name.endsWith(".md"))
    .map((entry) => entry.name)
    .sort();

  const openPlans = [];
  const closedPlans = [];

  for (const filename of filenames) {
    const fullPath = path.join(plansDir, filename);
    const content = fs.readFileSync(fullPath, "utf8");
    const frontmatter = parseFrontmatter(content);
    const checklist = countChecklistItems(content);

    const plan = {
      file: path.join("plans", filename),
      title: frontmatter.title || filename,
      state: frontmatter.state || "",
      priority: normalizePriority(frontmatter.priority),
      createdAt: frontmatter.created_at || "",
      closedAt: frontmatter.closed_at || "",
      agentSessions: normalizeAgentSessions(frontmatter),
      checklistDone: checklist.done,
      checklistTotal: checklist.total,
      completionPercent: completionPercent(checklist.done, checklist.total),
    };

    if (plan.state === "open") {
      openPlans.push(plan);
    } else if (plan.state === "closed") {
      closedPlans.push(plan);
    }
  }

  openPlans.sort((a, b) => compareOpenPlans(a, b, sort));
  closedPlans.sort((a, b) => compareDatesDescending(a.closedAt, b.closedAt));

  return { openPlans, closedPlans };
}

function stripFrontmatter(content) {
  if (!content.startsWith("---\n")) {
    return content;
  }

  const end = content.indexOf("\n---", 4);
  if (end === -1) {
    return content;
  }

  return content.slice(end + "\n---".length).replace(/^\r?\n/, "");
}

function headingLevel(line) {
  const match = line.match(/^(#{1,6})\s+/);
  return match ? match[1].length : null;
}

function extractGoalSection(content) {
  const lines = stripFrontmatter(content).split(/\r?\n/);
  const startIndex = lines.findIndex((line) => /^#{1,6}\s+Goal\s*$/i.test(line));

  if (startIndex === -1) {
    throw new Error("Plan does not contain a Goal section.");
  }

  const level = headingLevel(lines[startIndex]);
  let endIndex = lines.length;

  for (let index = startIndex + 1; index < lines.length; index += 1) {
    const nextLevel = headingLevel(lines[index]);
    if (nextLevel !== null && nextLevel <= level) {
      endIndex = index;
      break;
    }
  }

  const goalBody = lines.slice(startIndex + 1, endIndex).join("\n").trim();

  if (!goalBody) {
    throw new Error("Plan Goal section is empty.");
  }

  return goalBody;
}

function formatPlanReference(planPath) {
  const normalized = planPath.split(path.sep);
  const plansIndex = normalized.lastIndexOf("plans");

  if (plansIndex !== -1) {
    return normalized.slice(plansIndex).join("/");
  }

  return planPath;
}

function printGoalCommand(planPath) {
  if (!planPath) {
    throw new Error("goal requires a path to a plan");
  }

  const resolvedPlanPath = path.resolve(planPath);
  const content = fs.readFileSync(resolvedPlanPath, "utf8");
  const goalSection = extractGoalSection(content);
  const planReference = formatPlanReference(resolvedPlanPath);

  console.log(`/goal
${goalSection}

Use plan reference: ${planReference}.`);
}

function compareDatesDescending(a, b) {
  return b.localeCompare(a);
}

function compareOpenPlans(a, b, sort) {
  if (sort === "time") {
    return compareDatesDescending(a.createdAt, b.createdAt);
  }

  const priorityDifference =
    PRIORITIES.indexOf(a.priority) - PRIORITIES.indexOf(b.priority);
  if (priorityDifference !== 0) {
    return priorityDifference;
  }

  return compareDatesDescending(a.createdAt, b.createdAt);
}

function createReport(workingDir, openPlans, closedPlans) {
  return {
    workingDir,
    summary: {
      open: openPlans.length,
      closed: closedPlans.length,
    },
    openPlans,
    closedPlans,
  };
}

function padRight(value, width) {
  return String(value).padEnd(width, " ");
}

function printTable(rows, columns) {
  if (rows.length === 0) {
    console.log("  (none)");
    return;
  }

  const widths = columns.map((column) =>
    Math.max(
      column.label.length,
      ...rows.map((row) => String(column.value(row)).length),
    ),
  );

  console.log(
    columns
      .map((column, index) => padRight(column.label, widths[index]))
      .join("  "),
  );
  console.log(widths.map((width) => "-".repeat(width)).join("  "));

  for (const row of rows) {
    console.log(
      columns
        .map((column, index) => padRight(column.value(row), widths[index]))
        .join("  "),
    );
  }
}

function printSummary(summary) {
  console.log("Planrock Status");
  console.log(`Open:   ${summary.open}`);
  console.log(`Closed: ${summary.closed}`);
}

function formatAgentSessions(plan, fullAgentSession) {
  if (plan.agentSessions.length === 0) {
    return "-";
  }

  return plan.agentSessions
    .map((session) => formatAgentSessionId(session, fullAgentSession))
    .join(", ");
}

function openPlanColumns(fullAgentSession) {
  return [
    { label: "Priority", value: (plan) => plan.priority },
    { label: "Title", value: (plan) => plan.title },
    { label: "Created", value: (plan) => plan.createdAt },
    {
      label: "Done/Total",
      value: (plan) => `${plan.checklistDone}/${plan.checklistTotal}`,
    },
    { label: "Percent", value: (plan) => `${plan.completionPercent}%` },
    {
      label: "Agent Sessions",
      value: (plan) => formatAgentSessions(plan, fullAgentSession),
    },
  ];
}

function printOpenPlans(plans, fullAgentSession) {
  console.log("Open Plans");
  printTable(plans, openPlanColumns(fullAgentSession));
}

function printClosedPlans(plans) {
  console.log("Closed Plans");
  printTable(plans, [
    { label: "Closed", value: (plan) => plan.closedAt },
    { label: "Created", value: (plan) => plan.createdAt },
    { label: "Title", value: (plan) => plan.title },
  ]);
}

function printHumanReport(command, report, fullAgentSession) {
  console.log(`Working dir: ${report.workingDir}`);

  if (command === "open") {
    printOpenPlans(report.openPlans, fullAgentSession);
    return;
  }

  if (command === "closed") {
    printClosedPlans(report.closedPlans);
    return;
  }

  printSummary(report.summary);
  console.log("");
  console.log(`Top Open Plans (top ${STATUS_LIMIT})`);
  printTable(
    report.openPlans.slice(0, STATUS_LIMIT),
    openPlanColumns(fullAgentSession),
  );
  console.log("");
  console.log(`Most Recent Closed Plans (top ${STATUS_LIMIT})`);
  printTable(report.closedPlans.slice(0, STATUS_LIMIT), [
    { label: "Closed", value: (plan) => plan.closedAt },
    { label: "Created", value: (plan) => plan.createdAt },
    { label: "Title", value: (plan) => plan.title },
  ]);
}

function printJsonReport(command, report) {
  if (command === "open") {
    console.log(
      JSON.stringify(
        { workingDir: report.workingDir, openPlans: report.openPlans },
        null,
        2,
      ),
    );
    return;
  }

  if (command === "closed") {
    console.log(
      JSON.stringify(
        { workingDir: report.workingDir, closedPlans: report.closedPlans },
        null,
        2,
      ),
    );
    return;
  }

  console.log(
    JSON.stringify(
      {
        workingDir: report.workingDir,
        summary: report.summary,
        recentOpenPlans: report.openPlans.slice(0, STATUS_LIMIT),
        recentClosedPlans: report.closedPlans.slice(0, STATUS_LIMIT),
      },
      null,
      2,
    ),
  );
}

function printHelp() {
  console.log(`Usage: planrock [status|open|closed] [--working-dir <path>] [--sort priority|time] [--json] [--full-agent-session] [--version]
       planrock goal <path-to-plan>

Commands:
  status   Show summary plus the 10 highest-priority open plans and 10 most recent closed plans.
  open     Show all open plans, priority first by default.
  closed   Show all closed plans, newest closed first.
  goal     Print a Codex /goal command from a plan's Goal section.

Options:
  --working-dir <path>  Working directory containing plans/.
  --sort priority|time  Sort open plans by priority then created time, or by created time only.
  --full-agent-session  Show complete agent_sessions values in human tables.
  --json                Emit machine-readable JSON.
  --version             Print the planrock version.
`);
}

function main() {
  let options;

  try {
    options = parseArgs(process.argv.slice(2));
  } catch (error) {
    console.error(error.message);
    console.error("Usage: planrock [status|open|closed] [--working-dir <path>] [--sort priority|time] [--json] [--full-agent-session] [--version]");
    console.error("       planrock goal <path-to-plan>");
    process.exit(1);
  }

  if (options.command === "help") {
    printHelp();
    return;
  }

  if (options.command === "version") {
    console.log(packageJson.version);
    return;
  }

  if (options.command === "goal") {
    try {
      printGoalCommand(options.planPath);
    } catch (error) {
      console.error(error.message);
      process.exit(1);
    }

    return;
  }

  const workingDir = resolveWorkingDir(options.workingDir);
  const plansDir = path.join(workingDir, "plans");
  let openPlans;
  let closedPlans;

  try {
    ({ openPlans, closedPlans } = readPlans(plansDir, options.sort));
  } catch (error) {
    console.error(error.message);
    process.exit(1);
  }

  const report = createReport(workingDir, openPlans, closedPlans);

  if (options.json) {
    printJsonReport(options.command, report);
    return;
  }

  printHumanReport(options.command, report, options.fullAgentSession);
}

main();
